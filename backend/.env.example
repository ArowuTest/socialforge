# ─── SocialForge Backend — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
# All required variables are marked with (required).

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development                     # development | staging | production

# ── Database (required) ────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/socialforge?sslmode=disable

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT (required) ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# ── Application ─────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:3000
APP_NAME=SocialForge

# ── AI Services (configurable via admin UI) ────────────────────────────────
# These are fallback values. Admin can override via Settings > Integrations.
OPENAI_API_KEY=
FAL_API_KEY=

# ── Object Storage (S3-compatible — works with AWS S3, R2, Spaces, MinIO) ──
# Leave empty to disable media uploads.
STORAGE_ENDPOINT=                       # e.g. https://xyz.r2.cloudflarestorage.com (leave empty for AWS S3)
STORAGE_BUCKET=socialforge-media
STORAGE_REGION=auto                     # "auto" for R2, "us-east-1" for AWS, etc.
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=                     # CDN URL prefix, e.g. https://cdn.socialforge.io

# ── Stripe (optional — billing disabled when empty) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_YEARLY=

# ── Paystack (optional — for NGN/African payments) ──────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_PUBLIC_KEY=

# ── Email / Notifications (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@socialforge.io

# ── OAuth — Instagram / Facebook ────────────────────────────────────────────
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URL=
INSTAGRAM_SCOPES=instagram_basic,instagram_content_publish,pages_read_engagement

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL=
FACEBOOK_SCOPES=pages_manage_posts,pages_read_engagement,publish_to_groups

# ── OAuth — TikTok ──────────────────────────────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URL=
TIKTOK_SCOPES=user.info.basic,video.upload,video.publish

# ── OAuth — YouTube / Google ─────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URL=
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.upload,https://www.googleapis.com/auth/youtube.readonly

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=
GOOGLE_SCOPES=openid,email,profile

# ── OAuth — LinkedIn ─────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URL=
LINKEDIN_SCOPES=openid,profile,email,w_member_social

# ── OAuth — Twitter / X ──────────────────────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URL=
TWITTER_SCOPES=tweet.read,tweet.write,users.read,offline.access

# ── OAuth — Pinterest ────────────────────────────────────────────────────────
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URL=
PINTEREST_SCOPES=boards:read,pins:read,pins:write

# ── OAuth — Threads ──────────────────────────────────────────────────────────
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
THREADS_REDIRECT_URL=
THREADS_SCOPES=threads_basic,threads_content_publish
