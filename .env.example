# =============================================================================
# SocialForge — Backend Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8080
ENV=development

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://socialforge:password@localhost:5432/socialforge?sslmode=disable
POSTGRES_PASSWORD=password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://:password@localhost:6379
REDIS_PASSWORD=password

# -----------------------------------------------------------------------------
# JSON Web Tokens
# -----------------------------------------------------------------------------
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h

# -----------------------------------------------------------------------------
# Stripe — Payments & Subscriptions
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# OpenAI — AI Caption / Content Generation
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Fal.ai — Image / Video Generation
# -----------------------------------------------------------------------------
FAL_API_KEY=...

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Storage — Cloudflare R2 (S3-compatible)
# -----------------------------------------------------------------------------
STORAGE_BUCKET=socialforge-media
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=...
STORAGE_SECRET_KEY=...
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# -----------------------------------------------------------------------------
# OAuth — Instagram / Facebook
# -----------------------------------------------------------------------------
INSTAGRAM_CLIENT_ID=...
INSTAGRAM_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# OAuth — TikTok
# -----------------------------------------------------------------------------
TIKTOK_CLIENT_ID=...
TIKTOK_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# OAuth — YouTube / Google
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# OAuth — LinkedIn
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# OAuth — Twitter / X
# -----------------------------------------------------------------------------
TWITTER_CLIENT_ID=...
TWITTER_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# OAuth — Facebook (standalone app)
# -----------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=...
FACEBOOK_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# OAuth — Pinterest
# -----------------------------------------------------------------------------
PINTEREST_CLIENT_ID=...
PINTEREST_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# OAuth — Threads (uses Instagram / Meta)
# -----------------------------------------------------------------------------
THREADS_CLIENT_ID=...
THREADS_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# Dev Tools (used by docker-compose.dev.yml only)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@socialforge.io
PGADMIN_PASSWORD=admin
REDIS_COMMANDER_PASSWORD=admin
